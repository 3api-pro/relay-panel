# ===== relay-panel 一键部署环境变量 =====
# 复制为 .env 后按注释修改；带【必填】的项不填 compose 会直接报错。
# 完整说明见 ../docs/SELF-HOST.md

# --- 镜像构建 ---
# 国内网络可换 npm 镜像源，例如 https://registry.npmmirror.com
NPM_REGISTRY=https://registry.npmjs.org/

# --- 端口与绑定 ---
# 面板映射到宿主的地址与端口（默认只绑回环；公网请走反代或 caddy profile）
RP_BIND=127.0.0.1
RP_PORT=7100

# --- 编排器数据库 ---
# 【必填】compose 内置 postgres 的口令，请改成强随机值（openssl rand -hex 16）
POSTGRES_PASSWORD=
# 缺省用内置 postgres；要用外部库时取消注释：
# RP_DB=postgres://user:pass@db.example.com:5432/relay_panel

# --- 凭据加密主密钥 ---
# 【必填】建议 openssl rand -hex 32 生成 64 位 hex；丢失后已存的站点凭据无法解密
RP_SECRET_KEY=

# --- 首启 root 账号（仅 operators 空表时生效；也可事后用 CLI create-admin）---
RP_ADMIN_EMAIL=admin@example.com
RP_ADMIN_PASSWORD=

# --- 注册模式：closed(关闭注册) / invite(邀请制) / open(开放注册) ---
RP_SIGNUP_MODE=closed
# 登录会话有效期（小时）
RP_SESSION_TTL_HOURS=168

# --- 站点数据根目录 ---
# 【必填】铁律：该路径在容器内与宿主机必须完全一致（面板写下的引擎 compose 文件
# 是由宿主 docker daemon 解析的，路径不一致会导致挂载错位）
RP_SITES_ROOT=/srv/relay-panel/sites
# 面板开站分配的宿主端口池
RP_PORT_RANGE=18100-18999

# --- docker.sock 权限 ---
# 【必填】宿主 docker 组的 gid：getent group docker | cut -d: -f3
DOCKER_GID=998

# --- 告警监控 ---
# 监控周期毫秒；0=关闭。告警 webhook 在面板设置页配置（存 DB），无需环境变量
RP_MONITOR_INTERVAL_MS=60000
# >0 时启用渠道余额低于阈值告警（best-effort，取决于引擎是否透出余额字段）
RP_BALANCE_THRESHOLD=0

# --- 渠道市场计量网关（可选；不配置则 managed 模板不可启用）---
RP_METERING_GATEWAY_URL=
RP_METERING_GATEWAY_TOKEN=
# 账本拉取周期毫秒；0=关闭
RP_LEDGER_PULL_INTERVAL_MS=3600000

# --- 域名自动化（可选）---
# 启用 caddy profile 时设为 http://caddy:2019；不配置则域名只记录不下发
RP_CADDY_ADMIN_URL=

# --- Prometheus 抓取（可选）---
# 设置后 /metrics 可用 Authorization: Bearer <token> 免登录访问
RP_METRICS_TOKEN=
