# 3API Relay Panel — example config
# Copy to .env and fill in. Required ones marked [REQUIRED].

# === Server ===
NODE_ENV=production
PORT=8080
PUBLIC_URL=https://your-domain.com

# === Database ===
# SQLite (single-tenant default — file path)
DATABASE_TYPE=sqlite
DATABASE_URL=./data/3api.db

# OR PostgreSQL (required for multi-tenant mode)
# DATABASE_TYPE=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# === Tenant mode ===
TENANT_MODE=single   # 'single' for self-host (1 reseller); 'multi' for SaaS

# === Upstream (3API wholesale) === [REQUIRED]
UPSTREAM_BASE_URL=https://api.llmapi.pro/wholesale/v1
UPSTREAM_KEY=wsk-your-wholesale-key-here

# === Auth secrets === [REQUIRED]
JWT_SECRET=change-me-to-32-random-bytes-base64
ADMIN_DEFAULT_PASSWORD=change-on-first-login

# === SaaS-only (TENANT_MODE=multi) ===
# SAAS_DOMAIN=3api.pro
# SAAS_WILDCARD_CERT_DIR=/etc/letsencrypt/live/3api.pro

# === Optional ===
LOG_LEVEL=info
AUTO_UPDATE=on        # check for new releases weekly and docker pull
