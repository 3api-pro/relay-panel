# 3API Relay Panel — example config
# Copy to .env and fill required fields.

# === Server ===
NODE_ENV=production
PORT=8080
PUBLIC_URL=https://your-domain.com

# === Database (PostgreSQL required) ===
# When using bundled docker-compose, leave as-is. The panel container's
# DATABASE_URL is set via docker-compose.yml (overrides this default).
DATABASE_URL=postgresql://3api:3api_secret_change_me@localhost:5432/relay_panel

# === Tenant mode ===
TENANT_MODE=single   # 'single' for self-host; 'multi' for hosted SaaS

# === Upstream (3API wholesale) === [REQUIRED]
UPSTREAM_BASE_URL=https://api.llmapi.pro/wholesale/v1
UPSTREAM_KEY=wsk-your-wholesale-key-here

# === Auth secrets === [REQUIRED]
JWT_SECRET=change-me-to-32-random-bytes-base64
ADMIN_DEFAULT_PASSWORD=change-on-first-login

# === SaaS-only (TENANT_MODE=multi) ===
# SAAS_DOMAIN=3api.pro
# PLATFORM_TOKEN=long-random-bytes-here   # guards POST /platform/tenants etc.
#                                          # leave unset to disable platform routes

# === Optional ===
LOG_LEVEL=info
AUTO_UPDATE=on

# === Payments (Task #6, #7) ===
# Alipay — leave gateway=sandbox to use the in-process mock (smoke tests).
# Per-tenant credentials live in DB (tenant.config.payment_config); these
# env keys are fallbacks for single-tenant self-host.
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=
PUBLIC_BASE_URL=https://your-domain.com

# USDT — TronGrid is free-tier (no key). Etherscan needs a key.
TRONGRID_API=https://api.trongrid.io
# TRONGRID_API_KEY=
ETHERSCAN_API=https://api.etherscan.io/api
# ETHERSCAN_API_KEY=
# USDT_TRC20_ADDRESS=Txxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# USDT_ERC20_ADDRESS=0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
USDT_CNY_RATE=7.2
USDT_PAYMENT_TTL_MINUTES=30
USDT_WATCHER_ENABLED=on

# === Resend email (Task #12) ===
# RESEND_API_KEY=re_your_key   # leave unset for log-only / smoke-test mode
EMAIL_DEFAULT_FROM=noreply@3api.pro
EMAIL_CRON_ENABLED=on
