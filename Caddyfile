# 3API Caddyfile — auto-HTTPS via Let's Encrypt
# Replace YOUR_DOMAIN with your actual domain.

YOUR_DOMAIN {
    reverse_proxy panel:8080

    # Static assets (Next.js exports under /ui)
    handle_path /static/* {
        root * /app/public
        file_server
    }
}

